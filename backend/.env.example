# Serial port the Arduino is connected to.
# Linux/Pi: /dev/ttyUSB0 or /dev/ttyACM0
# macOS:    /dev/cu.usbmodem*
SERIAL_PORT=/dev/ttyUSB0

# Must match the baud rate in your Arduino sketch
BAUD_RATE=9600

# Port for the uvicorn server
PORT=8000

# WebSocket auth token — must match VITE_WS_TOKEN in the frontend
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WS_TOKEN=replace-with-a-long-random-secret

# Origin allowed to connect (your Vercel deployment URL)
ALLOWED_ORIGIN=https://your-app.vercel.app
